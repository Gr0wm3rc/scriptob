    ["250013"] = true, -- Trade Request Sent
    ["250014"] = true, -- One Trade Request Already Sent
    ["250015"] = true, -- Trade Request Rejected
    ["250016"] = true, -- Trade Cancel
    ["250017"] = true, -- Trade Complete
