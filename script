-- ========== TEvent / NETWORKING ==========
local function isTEventTable(value)
    return type(value) == "table"
        and type(value.FireRemote) == "function"
        and type(value.OnRemote) == "function"
end

local function finalizeTEvent(tev)
    if tev and tev.Setup then
        pcall(tev.Setup)
    end
    return tev
end

local function tryRequireTEventModule(modScript)
    if not modScript or not modScript:IsA("ModuleScript") then
        return nil
    end
    local ok, tev = pcall(require, modScript)
    if ok and isTEventTable(tev) then
        return finalizeTEvent(tev)
    end
    return nil
end

local function waitForGameBootstrap()
    ReplicatedStorage:WaitForChild("Shared", 60)
    ReplicatedStorage:WaitForChild("Remote_Event", 60)
    if not LocalPlayer.Character then
        LocalPlayer.CharacterAdded:Wait()
    end
    task.wait(CONFIG.BOOT_WAIT)
end

local function findDetachedTEventModule()
    local seen = {}
    local candidates = {}

    local function addCandidate(inst)
        if not inst or seen[inst] then
            return
        end
        seen[inst] = true
        if inst:IsA("ModuleScript") and inst.Name == "Module" then
            table.insert(candidates, inst)
        end
    end

    if getnilinstances then
        for _, inst in getnilinstances() do
            addCandidate(inst)
        end
    end

    if getgc then
        for _, obj in getgc(true) do
            if typeof(obj) == "Instance" then
                addCandidate(obj)
            end
        end
    end

    for _, modScript in candidates do
        local tev = tryRequireTEventModule(modScript)
        if tev then
            return tev
        end
    end
end

local function findCachedTEventTable()
    if getgc then
        for _, value in getgc(true) do
            if isTEventTable(value) then
                return finalizeTEvent(value)
            end
        end
    end

    if getreg then
        for _, value in getreg() do
            if isTEventTable(value) then
                return finalizeTEvent(value)
            end
        end
    end
end

local function findEventFolder()
    local core = ReplicatedStorage:FindFirstChild("Shared")
        and ReplicatedStorage.Shared:FindFirstChild("Core")
    local tevRoot = core and core:FindFirstChild("TEvent")

    if tevRoot then
        local eventFolder = tevRoot:FindFirstChild("Event")
        if eventFolder and eventFolder:FindFirstChild("RemoteEvent") then
            return eventFolder
        end
    end

    local gameEvent = game:FindFirstChild("Event")
    if gameEvent and gameEvent:FindFirstChild("RemoteEvent") then
        return gameEvent
    end

    if getnilinstances then
        for _, inst in getnilinstances() do
            if inst.Name == "Event" and inst:FindFirstChild("RemoteEvent") then
                return inst
            end
        end
    end
end

local function buildTEventShim(eventFolder)
    local okRemote, RemoteEvent = pcall(require, eventFolder:WaitForChild("RemoteEvent", 15))
    if not okRemote or type(RemoteEvent) ~= "table" or type(RemoteEvent.new) ~= "function" then
        return nil
    end

    pcall(RemoteEvent.SetupEventBinding)

    return finalizeTEvent({
        FireRemote = function(name, ...)
            RemoteEvent.new(name):FireServer(...)
        end,
        OnRemote = function(name, handler)
            return RemoteEvent.new(name).OnClientEvent:Connect(handler)
        end,
        Setup = function()
            pcall(RemoteEvent.SetupEventBinding)
        end,
    })
end

local function loadNetworking()
    waitForGameBootstrap()

    local root = ReplicatedStorage.Shared.Core:WaitForChild("TEvent", 60)
    local strategies = {
        function()
            return tryRequireTEventModule(root:FindFirstChild("Module"))
        end,
        function()
            return tryRequireTEventModule(root)
        end,
        findDetachedTEventModule,
        findCachedTEventTable,
        function()
            local eventFolder = findEventFolder()
            return eventFolder and buildTEventShim(eventFolder) or nil
        end,
    }

    while true do
        for _, strategy in ipairs(strategies) do
            local ok, net = pcall(strategy)
            if ok and isTEventTable(net) then
                return net
            end
        end
        task.wait(1)
    end
end

