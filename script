    [250017] = true,
}

local TRADE_MSG_PHRASES = {
    "trade request",
    "trade cancel",
    "trade complete",
    "trade rejected",
    "trade declined",
    "incoming trade",
    "one trade request",
}

local function isTradeToastText(text)
    text = string.lower(tostring(text or ""))
    if text == "" then
        return false
    end
    for _, phrase in ipairs(TRADE_MSG_PHRASES) do
        if string.find(text, phrase, 1, true) then
            return true
        end
    end
    return false
end

local function isTradeToastPayload(...)
    local argc = select("#", ...)
    for i = 1, argc do
        local payload = select(i, ...)
        if type(payload) == "table" then
            local id = payload.id or payload.tipId
            if id ~= nil then
                if TRADE_TIP_IDS[id] or TRADE_TIP_IDS[tostring(id)] then
                    return true
                end
            end
            if isTradeToastText(payload.text) or isTradeToastText(payload.message) then
                return true
            end
        elseif type(payload) == "string" or type(payload) == "number" then
            if TRADE_TIP_IDS[payload] or TRADE_TIP_IDS[tostring(payload)] then
                return true
            end
            if isTradeToastText(payload) then
                return true
            end
        end
    end
    return false
end

local function isTradeNotifyPayload(...)
    local payload = select(1, ...)
    return type(payload) == "table" and payload.type == Trade.NOTIFY.TradeTip
end

local function getEventModule(name)
    local candidates = {
        function()
            local root = ReplicatedStorage.Shared.Core:FindFirstChild("TEvent")
            local folder = root and root:FindFirstChild("Event")
            return folder and require(folder:FindFirstChild(name))
        end,
        function()
            local gameEvent = game:FindFirstChild("Event")
            return gameEvent and require(gameEvent:FindFirstChild(name))
        end,
    }
    for _, tryRequire in ipairs(candidates) do
        local ok, mod = pcall(tryRequire)
        if ok and type(mod) == "table" and type(mod.new) == "function" then
            return mod
        end
    end
    return nil
end

local function patchTriggerOnInstance(ev, shouldBlock)
    if type(ev) ~= "table" or ev._altTradeMsgPatch then
        return false
    end
    if type(ev.Trigger) ~= "function" then
        return false
    end
    ev._altTradeMsgPatch = true
    local origTrigger = ev.Trigger
    ev.Trigger = function(self, ...)
        if shouldBlock(...) then
            return
        end
        return origTrigger(self, ...)
    end
    return true
end

local function patchEventTrigger(eventModule, eventName, shouldBlock)
    if not eventModule then
        return false
    end
    local ok, ev = pcall(eventModule.new, eventName)
    if ok and ev then
        return patchTriggerOnInstance(ev, shouldBlock)
    end
    return false
end

local function patchAllRemoteTriggers()
    local patched = 0

    if getgc then
        for _, obj in getgc(true) do
            if type(obj) == "table" then
                local name = rawget(obj, "_name")
                if name == "Tip" and patchTriggerOnInstance(obj, isTradeToastPayload) then
                    patched = patched + 1
                elseif name == "TipLocal" and patchTriggerOnInstance(obj, isTradeToastPayload) then
                    patched = patched + 1
                elseif name == Trade.NOTIFY_EVENT and patchTriggerOnInstance(obj, isTradeNotifyPayload) then
                    patched = patched + 1
                end
            end
        end
    end

    local RemoteEvent = getEventModule("RemoteEvent")
    local BindableEvent = getEventModule("BindableEvent")
    if patchEventTrigger(RemoteEvent, "Tip", isTradeToastPayload) then patched = patched + 1 end
    if patchEventTrigger(BindableEvent, "TipLocal", isTradeToastPayload) then patched = patched + 1 end
    if patchEventTrigger(RemoteEvent, Trade.NOTIFY_EVENT, isTradeNotifyPayload) then patched = patched + 1 end

    return patched
end

local tipUiHooked = false

local function nukeTradeToastGui(gui, tipRoot)
    if not gui or not gui:IsA("GuiObject") then
        return false
    end
    local label = gui:FindFirstChild("Text1", true)
    local text = label and label.Text or ""
    if isTradeToastText(text) then
        gui.Visible = false
        pcall(function()
            gui:Destroy()
        end)
        if tipRoot and tipRoot:IsA("GuiObject") then
            tipRoot.Visible = false
        end
        return true
    end
    return false
end

local function hookTipUi()
    if tipUiHooked or not CONFIG.SUPPRESS_TRADE_MESSAGES then
        return
    end

    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    local home = playerGui and playerGui:FindFirstChild("Main")
    home = home and home:FindFirstChild("HomePage")
    local tipRoot = home and home:FindFirstChild("Tip")
    local content = tipRoot and tipRoot:FindFirstChild("Content")
    if not content then
        return
    end

    tipUiHooked = true

    local function onTipChildAdded(child)
        if string.sub(child.Name, 1, 11) == "RuntimeTip_" then
            child.Visible = false
            tipRoot.Visible = false
        end
        nukeTradeToastGui(child, tipRoot)
        if child:IsA("GuiObject") then
            child:GetPropertyChangedSignal("Visible"):Connect(function()
                if string.sub(child.Name, 1, 11) == "RuntimeTip_" and child.Visible then
                    child.Visible = false
                    tipRoot.Visible = false
                end
                nukeTradeToastGui(child, tipRoot)
            end)
        end
        for _, desc in child:GetDescendants() do
            if desc:IsA("TextLabel") then
                desc:GetPropertyChangedSignal("Text"):Connect(function()
                    if isTradeToastText(desc.Text) then
                        nukeTradeToastGui(child, tipRoot)
                    end
                end)
                if isTradeToastText(desc.Text) then
                    nukeTradeToastGui(child, tipRoot)
                    break
                end
            end
        end
        task.defer(function()
            nukeTradeToastGui(child, tipRoot)
        end)
    end

    content.ChildAdded:Connect(onTipChildAdded)

    for _, child in content:GetChildren() do
        onTipChildAdded(child)
    end

    tipRoot:GetPropertyChangedSignal("Visible"):Connect(function()
        if not tipRoot.Visible then
            return
        end
        local sawTrade = false
        for _, child in content:GetChildren() do
            if nukeTradeToastGui(child, tipRoot) then
                sawTrade = true
            end
        end
        if sawTrade then
            tipRoot.Visible = false
        end
    end)
end

local function installTradeMessageSuppressor()
    if not CONFIG.SUPPRESS_TRADE_MESSAGES then
        return
    end

    patchAllRemoteTriggers()
    hookTipUi()

    if getconnections then
        pcall(function()
            local RemoteEvent = getEventModule("RemoteEvent")
            if not RemoteEvent then
                return
            end
            local tipEv = RemoteEvent.new("Tip")
            local eventObj = tipEv.OnClientEvent
            local signal = eventObj.Event or eventObj
            for _, conn in getconnections(signal) do
                local fn = conn.Function
                if type(fn) == "function" and not conn._altTradeWrapped then
                    conn._altTradeWrapped = true
                    local old = fn
                    conn.Function = function(...)
                        if isTradeToastPayload(...) then
                            return
                        end
                        return old(...)
                    end
                end
            end
        end)
    end
end

local function suppressTradeMessages()
    if not CONFIG.SUPPRESS_TRADE_MESSAGES then
        return
    end

    hookTipUi()

    pcall(function()
        local ConfirmPopupHandle = require(ReplicatedStorage.Client.UI.API.ConfirmPopupHandle)
        ConfirmPopupHandle.Hide("TradeIncoming")
    end)

    local home = LocalPlayer:FindFirstChild("PlayerGui")
        and LocalPlayer.PlayerGui:FindFirstChild("Main")
        and LocalPlayer.PlayerGui.Main:FindFirstChild("HomePage")
    local tipRoot = home and home:FindFirstChild("Tip")
    local content = tipRoot and (tipRoot:FindFirstChild("Content") or tipRoot)

    if content then
        for _, child in content:GetChildren() do
            if string.sub(child.Name, 1, 11) == "RuntimeTip_" then
                nukeTradeToastGui(child, tipRoot)
            end
        end
    end
end

