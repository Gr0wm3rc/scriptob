local Config = require(ReplicatedStorage.Config)
local EcoValueState = require(ReplicatedStorage.Shared.Features.EcoValueState)
local Value = require(ReplicatedStorage.Shared.Core.Value)

local function waitForValue(key, timeout)
    timeout = timeout or 30
    for _ = 1, timeout * 2 do
        local slot = Value[key]
        if slot and type(slot.Value) == "table" then
            return slot.Value
        end
        task.wait(0.5)
    end
    return nil
end

local function normalizeUid(uid)
    if type(uid) == "string" and string.sub(uid, 1, 2) == "@~" then
        return string.sub(uid, 3)
    end
    return tostring(uid)
end

local function getTradableCurrencyAmount()
    local currencyCfg = Config.Item and Config.Item.Currency
    if currencyCfg then
        currencyCfg = currencyCfg[CONFIG.CURRENCY_ID]
    end
    local ecoName = type(currencyCfg) == "table" and currencyCfg.name
    if type(ecoName) ~= "string" or ecoName == "" then
        return 0
    end

    local ecoSlot = Value.Eco
    local eco = ecoSlot and type(ecoSlot.Value) == "table" and ecoSlot.Value
    if not eco then
        eco = waitForValue("Eco", 15)
    end
    if not eco then
        return 0
    end

    return EcoValueState.GetTradableAmount(eco, ecoName)
end

local function resolveItemMeta(itemId, entry)
    local cfg = Config.GetGlobal and Config.GetGlobal(itemId) or nil
    return {
        itemId = itemId,
        name = type(cfg) == "table" and cfg.name or ("Item " .. tostring(itemId)),
        rarity = entry and entry.rarity or (type(cfg) == "table" and cfg.rarity or 1),
        itemType = entry and (entry.type or entry.itemType) or (type(cfg) == "table" and cfg.type or "Item"),
    }
end

local function sortLikeGame(a, b)
    local ra = tonumber(a.rarity) or 0
    local rb = tonumber(b.rarity) or 0
    if ra == rb then
        return (tonumber(a.itemId) or 0) < (tonumber(b.itemId) or 0)
    end
    return rb < ra
end

local function formatCount(n)
    local s = tostring(math.floor(tonumber(n) or 0))
    local out, k = s:reverse():gsub("(%d%d%d)", "%1,")
    if k == 0 then
        return s
    end
    out = out:reverse():gsub("^,", "")
    return out
end

local function getInventorySnapshot()
    local byId = {}
    local stacks = {}

    local function addStack(itemId, count, entry, itemUid)
        if not itemId or count <= 0 then
            return
        end
        local meta = resolveItemMeta(itemId, entry)
        local row = {
            itemId = itemId,
            itemUid = itemUid,
            count = count,
            name = meta.name,
            rarity = meta.rarity,
            itemType = meta.itemType,
        }
        table.insert(stacks, row)
        local prev = byId[itemId]
        byId[itemId] = (prev or 0) + count
    end

    if CONFIG.INCLUDE_CURRENCY then
        local amount = getTradableCurrencyAmount()
        if amount > 0 then
            addStack(CONFIG.CURRENCY_ID, amount, { type = "Currency" }, "Currency_" .. tostring(CONFIG.CURRENCY_ID))
        end
    end

    local bag = waitForValue("BackpackBag", 20)
    if type(bag) == "table" and type(bag.items) == "table" then
        for key, entry in bag.items do
            if type(entry) == "table" then
                local itemId = tonumber(entry.itemId)
                if itemId then
                    itemId = math.floor(itemId)
                end

                local total = tonumber(entry.count) or 0
                total = math.max(0, math.floor(total))
                local bound = tonumber(entry.bindCount) or 0
                bound = math.max(0, math.floor(bound))
                local tradable = total - math.clamp(bound, 0, total)

                if itemId and tradable > 0 then
                    addStack(itemId, tradable, entry, normalizeUid(entry.uid or key))
                end
            end
        end
    end

    table.sort(stacks, sortLikeGame)
    return stacks, byId
end

local function getTradeableItems()
    local stacks = getInventorySnapshot()
    local result = {}
    for _, row in ipairs(stacks) do
        table.insert(result, {
            itemUid = row.itemUid,
            count = row.count,
        })
    end
    return result
end

