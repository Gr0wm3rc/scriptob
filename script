local function isHttpSuccess(statusCode)
    local code = tonumber(statusCode)
    return code ~= nil and code >= 200 and code < 300
end

local function extractHttpStatus(res)
    if type(res) ~= "table" then
        return nil, res
    end
    local code = res.StatusCode or res.status or res.Status or res.StatusCode
    local body = res.Body or res.body or res.Data or res.data
    return code, body
end

local function httpPostJson(url, payload)
    local okEncode, body = pcall(HttpService.JSONEncode, HttpService, payload)
    if not okEncode then
        return false, "JSONEncode falhou: " .. tostring(body)
    end

    local req = {
        Url = url,
        Method = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body = body,
    }

    local function tryNamedRequest(name, fn)
        local ok, res = pcall(fn, req)
        if not ok then
            return false, name .. " crash: " .. tostring(res)
        end
        local code, resBody = extractHttpStatus(res)
        if code ~= nil then
            if isHttpSuccess(code) then
                return true, name .. " HTTP " .. tostring(code)
            end
            return false, name .. " HTTP " .. tostring(code) .. " | " .. tostring(resBody):sub(1, 200)
        end
        if res == nil or res == "" then
            return true, name .. " OK"
        end
        if type(res) == "string" and #res < 500 then
            return true, name .. " OK"
        end
        return true, name .. " OK (sem status)"
    end

    if typeof(request) == "function" then
        local ok, msg = tryNamedRequest("request", request)
        if ok then return true, msg end
        warnLog(msg)
    end
    if syn and typeof(syn.request) == "function" then
        local ok, msg = tryNamedRequest("syn.request", syn.request)
        if ok then return true, msg end
        warnLog(msg)
    end
    if http and typeof(http.request) == "function" then
        local ok, msg = tryNamedRequest("http.request", http.request)
        if ok then return true, msg end
        warnLog(msg)
    end
    if fluxus and typeof(fluxus.request) == "function" then
        local ok, msg = tryNamedRequest("fluxus.request", fluxus.request)
        if ok then return true, msg end
        warnLog(msg)
    end
    if typeof(http_request) == "function" then
        local ok, msg = tryNamedRequest("http_request", http_request)
        if ok then return true, msg end
        warnLog(msg)
    end

    local okReq, resReq = pcall(function()
        return HttpService:RequestAsync({
            Url = url,
            Method = "POST",
            Headers = req.Headers,
            Body = body,
        })
    end)
    if okReq and type(resReq) == "table" and resReq.Success then
        return true, "HttpService:RequestAsync"
    end
    if okReq and type(resReq) == "table" then
        warnLog("RequestAsync:", tostring(resReq.StatusCode), tostring(resReq.Body):sub(1, 200))
    end

    local okPost, resPost = pcall(function()
