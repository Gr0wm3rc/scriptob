            if os.clock() - pendingSince >= CONFIG.REQUEST_TIMEOUT then
                local sessionId = session.sessionId
                if sessionId then
                    TradeApi.Cancel(sessionId)
                end
                resetTradeState()
                hideTradeHud()
                scheduleTradeRetry()
            end
        elseif STATE == "WAIT_ACCEPT" and not session and pendingSince > 0 then
            if os.clock() - pendingSince >= CONFIG.REQUEST_TIMEOUT then
                resetTradeState()
                scheduleTradeRetry()
            end
        end

        tryRequestTrade()
        task.wait(CONFIG.MONITOR_INTERVAL)
    end
end)

