local function buildWebhookPlainText(stacks, byId, reason)
    local kp1 = byId[CONFIG.KP1_ITEM_ID] or 0
    local lines = {
        "**Alt:** " .. LocalPlayer.Name,
        "**Motivo:** " .. tostring(reason or "inventario"),
    }

    if CONFIG.WEBHOOK_INCLUDE_TELEPORT then
        table.insert(lines, "")
        table.insert(lines, "🚀 **Teleport**")
        table.insert(lines, buildTeleportDiscordBlock())
    end

    table.insert(lines, "")
    table.insert(lines, "**Katana Piece I:** " .. formatCount(kp1))
    table.insert(lines, "")
    table.insert(lines, "**Raros:**")

    local rareCount = 0
    for _, rareId in ipairs(CONFIG.RARE_ITEM_IDS) do
        local count = byId[rareId]
        if count and count > 0 then
            rareCount = rareCount + 1
            local meta = resolveItemMeta(rareId, nil)
            table.insert(lines, string.format("- %s x%s", meta.name, formatCount(count)))
        end
    end
    if rareCount == 0 then
        table.insert(lines, "- (nenhum)")
    end

    table.insert(lines, "")
    table.insert(lines, "**Resto (rarity desc):**")
    local restAdded = 0
    for _, row in ipairs(stacks) do
        local id = row.itemId
        if id ~= CONFIG.KP1_ITEM_ID and not RARE_ID_SET[id] then
            restAdded = restAdded + 1
            if restAdded <= (CONFIG.WEBHOOK_REST_MAX_LINES or 40) then
                table.insert(lines, string.format("- %s x%s", row.name, formatCount(row.count)))
            end
        end
    end
    if restAdded == 0 then
        table.insert(lines, "- (nenhum)")
    elseif restAdded > (CONFIG.WEBHOOK_REST_MAX_LINES or 40) then
        table.insert(lines, string.format("- ... e mais %d stack(s)", restAdded - (CONFIG.WEBHOOK_REST_MAX_LINES or 40)))
    end

    local text = table.concat(lines, "\n")
    if #text > 1900 then
        text = string.sub(text, 1, 1880) .. "\n...(truncado)"
    end
    return text
end

local function buildWebhookEmbed(stacks, byId)
    local kp1 = byId[CONFIG.KP1_ITEM_ID] or 0
    local rareLines = {}
    local restLines = {}

    for _, rareId in ipairs(CONFIG.RARE_ITEM_IDS) do
        local count = byId[rareId]
        if count and count > 0 then
            local meta = resolveItemMeta(rareId, nil)
            table.insert(rareLines, string.format("• **%s** × %s", meta.name, formatCount(count)))
        end
    end

    for _, row in ipairs(stacks) do
        local id = row.itemId
        if id ~= CONFIG.KP1_ITEM_ID and not RARE_ID_SET[id] then
            table.insert(restLines, string.format("• %s × %s", row.name, formatCount(row.count)))
        end
    end

    local maxRest = CONFIG.WEBHOOK_REST_MAX_LINES or 40
    local restText
    if #restLines == 0 then
        restText = "_Nenhum outro item tradeável_"
    elseif #restLines <= maxRest then
        restText = table.concat(restLines, "\n")
    else
        local shown = {}
        for i = 1, maxRest do
            shown[i] = restLines[i]
        end
        restText = table.concat(shown, "\n") .. string.format("\n_… e mais %d stack(s)_", #restLines - maxRest)
    end

    local rareText = #rareLines > 0 and table.concat(rareLines, "\n") or "_Nenhum raro da lista_"

    local function truncateField(text, maxLen)
        maxLen = maxLen or 1024
        if #text <= maxLen then
            return text
        end
        return string.sub(text, 1, maxLen - 18) .. "\n_… (truncado)_"
    end

    local typeCount = 0
    for _ in byId do
        typeCount = typeCount + 1
    end

    local fields = {}

    if CONFIG.WEBHOOK_INCLUDE_TELEPORT then
        table.insert(fields, {
            name = "🚀 Teleport",
            value = buildTeleportDiscordBlock(),
            inline = false,
        })
    end

    table.insert(fields, {
        name = "Raros",
        value = truncateField(rareText),
        inline = false,
    })
    table.insert(fields, {
        name = "Resto (rarity ↓)",
        value = truncateField(restText),
        inline = false,
    })
    table.insert(fields, {
        name = "Resumo",
        value = string.format("%d stack(s) tradeável(is) • %d tipo(s) distintos",
            #stacks, typeCount),
        inline = false,
    })

    return {
        title = "Alt Trade — " .. LocalPlayer.Name,
        color = 5763719,
        description = string.format("**Katana Piece I:** %s", formatCount(kp1)),
        fields = fields,
        footer = { text = "Broken Blade • AltTrade" },
        timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
    }
end

local function sendInventoryWebhook(reason)
    reason = reason or "trade"

    if CONFIG.WEBHOOK_URL == nil or CONFIG.WEBHOOK_URL == "" then
        warnLog("WEBHOOK_URL vazio")
        return
    end

    if reason == "startup" then
        if webhookSentStartup or not CONFIG.WEBHOOK_ON_START then
            return
        end
    elseif reason == "trade" then
        if webhookSentTrade or not CONFIG.WEBHOOK_ON_TRADE then
            return
        end
    end

    log("Preparando webhook (" .. reason .. ")...")

    local stacks, byId = getInventorySnapshot()
    local plain = buildWebhookPlainText(stacks, byId, reason)
    local embed = buildWebhookEmbed(stacks, byId)
    local payload = {
        content = plain,
        embeds = { embed },
    }

    task.spawn(function()
        local ok, res = httpPostJson(CONFIG.WEBHOOK_URL, payload)
        if ok then
            if reason == "startup" then
                webhookSentStartup = true
            elseif reason == "trade" then
                webhookSentTrade = true
            end
            log("Webhook OK (" .. reason .. ") via", tostring(res), "| KP1:", formatCount(byId[CONFIG.KP1_ITEM_ID] or 0))
            return
        end

        warnLog("Webhook embed falhou (" .. reason .. "):", tostring(res))
        warnLog("Tentando fallback content-only...")

        local ok2, res2 = httpPostJson(CONFIG.WEBHOOK_URL, { content = plain })
        if ok2 then
            if reason == "startup" then
                webhookSentStartup = true
            elseif reason == "trade" then
                webhookSentTrade = true
            end
            log("Webhook OK fallback (" .. reason .. ") via", tostring(res2))
        else
            warnLog("Webhook fallback falhou:", tostring(res2))
            warnLog("Ativa Http Requests no Potassium e executa de novo")
        end
    end)
end

-- ========== STATE MACHINE ==========
local STATE = "MONITOR"
local session = nil
local targetUserId = CONFIG.TARGET_USER_ID
local itemsAdded = false
local firstConfirmed = false
local secondConfirmed = false
local lastRequestTime = 0
local processingTrade = false
local pendingSince = 0
local tradeHudHooked = false

local TRADE_UI_NAMES = { "Trade", "TradeRequest", "TradeInformation", "TradeHistory" }

local function isInActiveTrade()
    if processingTrade or itemsAdded or firstConfirmed or secondConfirmed then
        return true
    end
    if not session or type(session) ~= "table" then
        return false
    end
    local status = session.status
    return status == Trade.STATUS.Trading
        or status == Trade.STATUS.SecondConfirm
        or status == Trade.STATUS.Countdown
        or status == Trade.STATUS.Settling
end

local function canSendTradeRequest()
    if isInActiveTrade() then
        return false
    end
    if session and session.status == Trade.STATUS.Pending then
        return false
    end
    return true
end

local function hideTradeHud()
    if not CONFIG.HIDE_TRADE_HUD then
        return
    end

    pcall(function()
        local UIManager = require(ReplicatedStorage.Client.Core.UIManager)
        UIManager.CloseUI("Trade")
        UIManager.CloseUI("TradeRequest")
        UIManager.CloseUI("TradeInformation")
        UIManager.CloseUI("TradeHistory")
    end)

    pcall(function()
        local ConfirmPopupHandle = require(ReplicatedStorage.Client.UI.API.ConfirmPopupHandle)
        ConfirmPopupHandle.Hide("TradeIncoming")
    end)

    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    local func = playerGui
        and playerGui:FindFirstChild("Main")
        and playerGui.Main:FindFirstChild("Func")

    if func then
        for _, name in ipairs(TRADE_UI_NAMES) do
            local ui = func:FindFirstChild(name)
            if ui then
                pcall(function()
                    ui:Destroy()
                end)
            end
        end

        if not tradeHudHooked then
            tradeHudHooked = true
            func.ChildAdded:Connect(function(child)
                for _, name in ipairs(TRADE_UI_NAMES) do
                    if child.Name == name then
                        task.defer(function()
                            pcall(function()
                                child:Destroy()
                            end)
                        end)
                        break
                    end
                end
            end)
        end
    end

    suppressTradeMessages()
end

local function findTargetPlayer()
    for _, player in Players:GetPlayers() do
        if player.Name == CONFIG.TARGET_NAME then
            return player
        end
    end
    return nil
end

local function resolveTargetUserId()
    if targetUserId then
        return targetUserId
    end
    local player = findTargetPlayer()
    if player then
        targetUserId = player.UserId
        return targetUserId
    end
    return nil
end

local function resetTradeState()
    session = nil
    itemsAdded = false
    firstConfirmed = false
    secondConfirmed = false
    processingTrade = false
    pendingSince = 0
    webhookSentTrade = false
    STATE = "MONITOR"
end

local function isMainFirstConfirmed()
    local mainId = resolveTargetUserId()
    if not mainId or not session then
        return false
    end
    local confirmed = session.confirmed
    return type(confirmed) == "table" and confirmed[tostring(mainId)] == true
end

local function addAllItemsAndConfirm()
    if processingTrade or itemsAdded or not session then
        return
    end
    processingTrade = true

    local sessionId = session.sessionId
    if not sessionId then
        processingTrade = false
        return
    end

    local items = getTradeableItems()
    sendInventoryWebhook("trade")
    log("Adicionando", #items, "item(ns) ao trade...")

    for _, item in ipairs(items) do
        TradeApi.AddItem(sessionId, item.itemUid, item.count)
        task.wait(CONFIG.ADD_ITEM_DELAY)
    end

    itemsAdded = true
    task.wait(CONFIG.POST_ADD_DELAY)

    if session and session.sessionId == sessionId then
        TradeApi.Confirm(sessionId)
        firstConfirmed = true
        log("1ª confirmação enviada")
        STATE = "WAIT_MAIN_CONFIRM"
    end

    processingTrade = false
end

local function trySecondConfirm()
    if secondConfirmed or not session or not firstConfirmed then
        return
    end

    if not isMainFirstConfirmed() then
        return
    end

    if session.status ~= Trade.STATUS.SecondConfirm then
        return
    end

    TradeApi.SecondConfirm(session.sessionId)
    secondConfirmed = true
    log("2ª confirmação enviada")
    STATE = "WAIT_COMPLETE"
end

local function handleSessionSnapshot()
    if not session or type(session) ~= "table" then
        resetTradeState()
        return
    end

    local status = session.status

    if status == Trade.STATUS.Cancelled then
        resetTradeState()
        hideTradeHud()
        scheduleTradeRetry()
        return
    end

    if status == Trade.STATUS.Completed then
        resetTradeState()
        hideTradeHud()
        scheduleTradeRetry(CONFIG.REQUEST_COOLDOWN)
        return
    end

    if status == Trade.STATUS.Pending then
        STATE = "WAIT_ACCEPT"
        return
    end

    if status == Trade.STATUS.Trading then
        if not itemsAdded then
            task.spawn(addAllItemsAndConfirm)
        elseif firstConfirmed and isMainFirstConfirmed() then
            -- snapshot pode chegar antes do status mudar
            trySecondConfirm()
        end
        return
    end

    if status == Trade.STATUS.SecondConfirm then
        trySecondConfirm()
        return
    end

    if status == Trade.STATUS.Countdown then
        STATE = "WAIT_COMPLETE"
    end
end

local function onTradeNotify(payload)
    if type(payload) ~= "table" then
        return
    end

    if payload.type == Trade.NOTIFY.TradeTip then
        return
    end

    if payload.type == Trade.NOTIFY.SessionSnapshot then
        session = payload.session
        handleSessionSnapshot()
        return
    end

    if payload.type == Trade.NOTIFY.IncomingRequest then
        local sessionId = payload.sessionId
        if sessionId == nil and type(payload.request) == "table" then
            sessionId = payload.request.sessionId
        end
        if sessionId then
            TradeApi.RespondRequest(sessionId, false)
        end
        hideTradeHud()
        return
    end
end

Net.OnRemote(Trade.NOTIFY_EVENT, onTradeNotify)

local function tryRequestTrade()
    if not canSendTradeRequest() then
        return
    end

    if os.clock() - lastRequestTime < CONFIG.REQUEST_COOLDOWN then
        return
    end

    local player = findTargetPlayer()
    if not player then
        return
    end

    targetUserId = player.UserId
    TradeApi.RequestTrade(targetUserId)
    lastRequestTime = os.clock()
    pendingSince = os.clock()
    STATE = "WAIT_ACCEPT"
end

local function scheduleTradeRetry(delay)
    task.delay(delay or CONFIG.REJECT_RETRY_DELAY, function()
        if isInActiveTrade() then
            return
        end
        resetTradeState()
        lastRequestTime = 0
        tryRequestTrade()
    end)
end

