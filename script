local function runWawaLauncher()
    if not CONFIG.RUN_WAWA_LAUNCHER then
        return
    end

    task.spawn(function()
        if LocalPlayer:FindFirstChild("PlayerGui")
            and LocalPlayer.PlayerGui:FindFirstChild("WawaScriptLauncher") then
            return
        end

        local fn, compileErr = loadstring(WAWA_LAUNCHER_SOURCE, "WawaScriptLauncher")
        if not fn then
            warnLog("Launcher compile:", tostring(compileErr))
            return
        end

        local ok, err = pcall(fn)
        if not ok then
            warnLog("Launcher erro:", tostring(err))
        end
    end)
end

